<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mobile_imei_wizard_form" model="ir.ui.view">
        <field name="name">mobile.imei.wizard.form</field>
        <field name="model">mobile.imei.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate / Import IMEI">
                <group>
                    <field name="production_id" readonly="1"/>
                    <field name="method"/>
                    <field name="quantity"/>
                    <field name="dual_sim"/>
                    <field name="enforce_luhn" readonly="1"/>
                </group>
                <group string="Automatic Generation" invisible="method != 'auto'">
                    <field name="tac_prefix"/>
                    <field name="tac_prefix_2" invisible="not dual_sim"/>
                    <button name="action_generate_preview" type="object" string="Generate Preview" class="btn-secondary"/>
                </group>
                <group string="Paste IMEI List" invisible="method != 'text'">
                    <div class="text-muted">One device per line. Dual-SIM format: IMEI1,IMEI2</div>
                    <field name="serial_numbers" nolabel="1" placeholder="356789120000011,356789120000029"/>
                </group>
                <group string="CSV Upload" invisible="method != 'csv'">
                    <field name="csv_file" filename="csv_filename"/>
                    <field name="csv_filename" invisible="1"/>
                    <div class="text-muted">Supported headers: imei1, imei2. The second column is optional for single-SIM devices.</div>
                </group>
                <footer>
                    <button name="action_apply" type="object" string="Assign IMEIs" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
