<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mobile_raw_receipt_list" model="ir.ui.view">
        <field name="name">mobile.raw.receipt.list</field>
        <field name="model">mobile.raw.receipt</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'qc_done'" decoration-muted="state == 'cancel'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="warehouse_id"/>
                <field name="scheduled_date"/>
                <field name="picking_id"/>
                <field name="state" widget="badge"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_mobile_raw_receipt_search" model="ir.ui.view">
        <field name="name">mobile.raw.receipt.search</field>
        <field name="model">mobile.raw.receipt</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="picking_id"/>
                <filter name="pending" string="Pending" domain="[('state', 'not in', ['qc_done', 'cancel'])]"/>
                <filter name="completed" string="Completed" domain="[('state', '=', 'qc_done')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_vendor" string="Vendor" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_mobile_raw_receipt_form" model="ir.ui.view">
        <field name="name">mobile.raw.receipt.form</field>
        <field name="model">mobile.raw.receipt</field>
        <field name="arch" type="xml">
            <form string="Raw Material Receipt">
                <header>
                    <button name="action_create_receipt" type="object" string="Create Odoo Receipt" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_confirm_received" type="object" string="Confirm Receipt &amp; Create QC" class="btn-primary" invisible="state != 'waiting_receipt'"/>
                    <button name="action_open_picking" type="object" string="Open Receipt Transfer" invisible="not picking_id"/>
                    <button name="action_open_raw_qc" type="object" string="Open Incoming QC" invisible="not raw_qc_id"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ['qc_done', 'cancel']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,waiting_receipt,received,qc_done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_picking" type="object" class="oe_stat_button" icon="fa-truck" invisible="not picking_id">
                            <field name="picking_id" string="Receipt" widget="statinfo"/>
                        </button>
                        <button name="action_open_raw_qc" type="object" class="oe_stat_button" icon="fa-check-square-o" invisible="not raw_qc_id">
                            <field name="raw_qc_id" string="Incoming QC" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="partner_id" readonly="state != 'draft'"/>
                            <field name="config_id" readonly="state != 'draft'"/>
                            <field name="warehouse_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="scheduled_date" readonly="state != 'draft'"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="1"/>
                            <field name="picking_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Raw Materials">
                            <field name="line_ids" readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="uom_id"/>
                                    <field name="note" optional="show"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes"><field name="notes"/></page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_mobile_raw_receipt" model="ir.actions.act_window">
        <field name="name">Raw Material Receipts</field>
        <field name="res_model">mobile.raw.receipt</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_mobile_raw_receipt_search"/>
    </record>
</odoo>
