<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mobile_packaging_list" model="ir.ui.view">
        <field name="name">mobile.packaging.batch.list</field>
        <field name="model">mobile.packaging.batch</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'done'" decoration-warning="state == 'ready'">
                <field name="name"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="box_capacity"/>
                <field name="remaining_qty"/>
                <field name="package_id"/>
                <field name="packed_date"/>
                <field name="state" widget="badge"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_mobile_packaging_form" model="ir.ui.view">
        <field name="name">mobile.packaging.batch.form</field>
        <field name="model">mobile.packaging.batch</field>
        <field name="arch" type="xml">
            <form string="IMEI Box Packaging">
                <header>
                    <button name="action_close_and_print" type="object" string="Close Box &amp; Print IMEI List" class="btn-primary" invisible="state not in ['draft', 'ready']"/>
                    <button name="action_close_and_print" type="object" string="Reprint IMEI List" invisible="state != 'done'"/>
                    <button name="action_remove_last_scan" type="object" string="Remove Last Scan" invisible="state == 'done' or not line_ids"/>
                    <button name="action_open_finished_picking" type="object" string="Open Finished Goods Transfer" invisible="not finished_picking_id"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,ready,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_finished_picking" type="object" class="oe_stat_button" icon="fa-truck" invisible="not finished_picking_id">
                            <field name="finished_picking_id" widget="statinfo" string="FG Transfer"/>
                        </button>
                    </div>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="config_id" readonly="state == 'done'"/>
                            <field name="product_id" readonly="1"/>
                            <field name="box_capacity" readonly="state == 'done'"/>
                            <field name="allow_partial_box" groups="mobile_manufacturing_management.group_mobile_mfg_manager" readonly="state == 'done'"/>
                        </group>
                        <group>
                            <field name="quantity" readonly="1"/>
                            <field name="remaining_qty" readonly="1"/>
                            <field name="package_id" readonly="1"/>
                            <field name="packed_by_id" readonly="1"/>
                            <field name="packed_date" readonly="1"/>
                        </group>
                    </group>
                    <div class="o_mobile_mfg_scan_panel" invisible="state == 'done'">
                        <h3>Scan IMEI Barcode</h3>
                        <p class="text-muted">Save the box first, then scan IMEI 1 or IMEI 2. The box becomes Ready automatically at the configured capacity.</p>
                        <field name="_barcode_scanned" widget="barcode_handler" placeholder="Scan IMEI barcode here..."/>
                    </div>
                    <notebook>
                        <page string="Scanned IMEIs">
                            <field name="line_ids" readonly="1">
                                <list>
                                    <field name="scan_sequence"/>
                                    <field name="imei_1"/>
                                    <field name="imei_2" optional="show"/>
                                    <field name="product_id"/>
                                    <field name="production_id" optional="show"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes"><field name="note"/></page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_mobile_packaging" model="ir.actions.act_window">
        <field name="name">IMEI Box Packaging</field>
        <field name="res_model">mobile.packaging.batch</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
