<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mobile_qc_scanner_form" model="ir.ui.view">
        <field name="name">mobile.qc.scanner.form</field>
        <field name="model">mobile.qc.scanner</field>
        <field name="arch" type="xml">
            <form string="Barcode / IMEI QC Scanner">
                <sheet>
                    <group>
                        <field name="stage"/>
                    </group>
                    <div class="o_mobile_mfg_scan_panel">
                        <h2>Scan Device IMEI</h2>
                        <field name="_barcode_scanned" widget="barcode_handler" placeholder="Scan IMEI 1 or IMEI 2..."/>
                    </div>
                    <group string="Scanned Device" invisible="not device_id">
                        <group>
                            <field name="device_id" readonly="1"/>
                            <field name="imei_1" readonly="1"/>
                            <field name="imei_2" readonly="1"/>
                        </group>
                        <group>
                            <field name="product_id" readonly="1"/>
                            <field name="current_state" readonly="1"/>
                        </group>
                    </group>
                    <group string="Functional Checklist" col="3" invisible="not device_id">
                        <field name="checklist_display_touch"/>
                        <field name="checklist_camera"/>
                        <field name="checklist_audio"/>
                        <field name="checklist_charging"/>
                        <field name="checklist_network"/>
                        <field name="checklist_wifi_bt"/>
                        <field name="checklist_software"/>
                        <field name="checklist_imei"/>
                        <field name="checklist_cosmetic"/>
                    </group>
                    <group string="Failure Information" invisible="not device_id">
                        <field name="failure_category"/>
                        <field name="failure_description"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_pass_and_next" type="object" string="PASS &amp; Scan Next" class="btn-primary" invisible="not device_id"/>
                    <button name="action_fail_and_rework" type="object" string="FAIL &amp; Send to Rework" class="btn-secondary" invisible="not device_id"/>
                    <button string="Close" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mobile_qc_scanner" model="ir.actions.act_window">
        <field name="name">Barcode QC Scanner</field>
        <field name="res_model">mobile.qc.scanner</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
