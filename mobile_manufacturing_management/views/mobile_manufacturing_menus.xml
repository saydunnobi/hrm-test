<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_mobile_manufacturing_orders" model="ir.actions.act_window">
        <field name="name">Mobile Manufacturing Orders</field>
        <field name="res_model">mrp.production</field>
        <field name="view_mode">list,kanban,form,calendar,pivot,graph</field>
        <field name="domain">[('is_mobile_manufacturing', '=', True)]</field>
        <field name="context">{'default_is_mobile_manufacturing': True}</field>
    </record>

    <menuitem id="menu_mobile_manufacturing_root"
              name="Mobile Manufacturing"
              sequence="35"
              groups="mobile_manufacturing_management.group_mobile_mfg_user"/>

    <menuitem id="menu_mobile_raw_material_root"
              name="Raw Materials"
              parent="menu_mobile_manufacturing_root"
              sequence="10"/>
    <menuitem id="menu_mobile_raw_receipt"
              name="Raw Material Receipts"
              parent="menu_mobile_raw_material_root"
              action="action_mobile_raw_receipt"
              sequence="10"/>
    <menuitem id="menu_mobile_raw_qc"
              name="Incoming IE/QC"
              parent="menu_mobile_raw_material_root"
              action="action_mobile_raw_qc"
              sequence="20"
              groups="mobile_manufacturing_management.group_mobile_mfg_qc"/>

    <menuitem id="menu_mobile_production_root"
              name="Production"
              parent="menu_mobile_manufacturing_root"
              sequence="20"/>
    <menuitem id="menu_mobile_material_requisition"
              name="Production Requisitions"
              parent="menu_mobile_production_root"
              action="action_mobile_material_requisition"
              sequence="10"/>
    <menuitem id="menu_mobile_mos"
              name="Manufacturing Orders"
              parent="menu_mobile_production_root"
              action="action_mobile_manufacturing_orders"
              sequence="20"/>
    <menuitem id="menu_mobile_production_qc"
              name="Pre-IMEI Production QC"
              parent="menu_mobile_production_root"
              action="action_mobile_production_qc"
              sequence="30"
              groups="mobile_manufacturing_management.group_mobile_mfg_qc"/>
    <menuitem id="menu_mobile_rework"
              name="Rework Orders"
              parent="menu_mobile_production_root"
              action="action_mobile_rework"
              sequence="40"/>

    <menuitem id="menu_mobile_quality_root"
              name="IMEI Quality"
              parent="menu_mobile_manufacturing_root"
              sequence="30"
              groups="mobile_manufacturing_management.group_mobile_mfg_qc"/>
    <menuitem id="menu_mobile_qc_scanner"
              name="Barcode QC Scanner"
              parent="menu_mobile_quality_root"
              action="action_mobile_qc_scanner"
              sequence="10"/>
    <menuitem id="menu_mobile_device_qc_history"
              name="Device QC History"
              parent="menu_mobile_quality_root"
              action="action_mobile_device_qc"
              sequence="20"/>
    <menuitem id="menu_mobile_devices"
              name="IMEI Device Registry"
              parent="menu_mobile_quality_root"
              action="action_mobile_device"
              sequence="30"/>

    <menuitem id="menu_mobile_packaging_root"
              name="Packaging"
              parent="menu_mobile_manufacturing_root"
              sequence="40"/>
    <menuitem id="menu_mobile_packaging"
              name="IMEI Box Packaging"
              parent="menu_mobile_packaging_root"
              action="action_mobile_packaging"
              sequence="10"
              groups="mobile_manufacturing_management.group_mobile_mfg_qc"/>

    <menuitem id="menu_mobile_configuration_root"
              name="Configuration"
              parent="menu_mobile_manufacturing_root"
              sequence="90"
              groups="mobile_manufacturing_management.group_mobile_mfg_manager"/>
    <menuitem id="menu_mobile_configuration"
              name="Manufacturing Setup"
              parent="menu_mobile_configuration_root"
              action="action_mobile_mfg_config"
              sequence="10"/>
</odoo>
