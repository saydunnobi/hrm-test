<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mobile_rework_list" model="ir.ui.view">
        <field name="name">mobile.rework.order.list</field>
        <field name="model">mobile.rework.order</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'done'" decoration-warning="state == 'in_progress'" decoration-muted="state == 'cancel'">
                <field name="name"/>
                <field name="device_id"/>
                <field name="production_id"/>
                <field name="quantity"/>
                <field name="return_stage" widget="badge"/>
                <field name="assigned_to_id"/>
                <field name="start_time"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_mobile_rework_form" model="ir.ui.view">
        <field name="name">mobile.rework.order.form</field>
        <field name="model">mobile.rework.order</field>
        <field name="arch" type="xml">
            <form string="Mobile Rework Order">
                <header>
                    <button name="action_start" type="object" string="Start Rework" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_complete" type="object" string="Complete &amp; Return to QC" class="btn-primary" invisible="state not in ['draft', 'in_progress']"/>
                    <button name="action_open_component_picking" type="object" string="Open Component Consumption" invisible="not component_consumption_picking_id"/>
                    <button name="action_open_return_picking" type="object" string="Open Return Transfer" invisible="not return_picking_id"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ['done', 'cancel']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="device_id"/>
                            <field name="production_id" readonly="1"/>
                            <field name="production_qc_id" readonly="1"/>
                            <field name="failed_qc_id" readonly="1"/>
                            <field name="quantity"/>
                        </group>
                        <group>
                            <field name="return_stage"/>
                            <field name="assigned_to_id"/>
                            <field name="start_time" readonly="1"/>
                            <field name="end_time" readonly="1"/>
                            <field name="component_consumption_picking_id" readonly="1"/>
                            <field name="return_picking_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Failure and Repair">
                        <field name="failure_category"/>
                        <field name="failure_description"/>
                        <field name="root_cause"/>
                        <field name="repair_action"/>
                    </group>
                    <notebook>
                        <page string="Replaced / Used Components">
                            <field name="component_line_ids" readonly="state == 'done'">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="uom_id"/>
                                    <field name="lot_id" optional="show"/>
                                    <field name="note" optional="show"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_mobile_rework" model="ir.actions.act_window">
        <field name="name">Rework Orders</field>
        <field name="res_model">mobile.rework.order</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
