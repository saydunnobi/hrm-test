<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mobile_device_qc_list" model="ir.ui.view">
        <field name="name">mobile.device.qc.list</field>
        <field name="model">mobile.device.qc</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'pass'" decoration-danger="state == 'fail'">
                <field name="name"/>
                <field name="imei_1"/>
                <field name="product_id"/>
                <field name="stage" widget="badge"/>
                <field name="inspector_id"/>
                <field name="scan_time"/>
                <field name="state" widget="badge"/>
                <field name="failure_category" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_mobile_device_qc_form" model="ir.ui.view">
        <field name="name">mobile.device.qc.form</field>
        <field name="model">mobile.device.qc</field>
        <field name="arch" type="xml">
            <form string="IMEI Device QC">
                <header>
                    <button name="action_pass" type="object" string="Pass" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_fail" type="object" string="Fail &amp; Send to Rework" class="btn-secondary" invisible="state != 'draft'"/>
                    <button name="action_open_transfer" type="object" string="Open Movement" invisible="not transfer_id"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pass,fail"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="device_id" readonly="state != 'draft'"/>
                            <field name="imei_1" readonly="1"/>
                            <field name="imei_2" readonly="1"/>
                            <field name="product_id" readonly="1"/>
                            <field name="production_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="stage" readonly="state != 'draft'"/>
                            <field name="inspector_id"/>
                            <field name="scan_time"/>
                            <field name="transfer_id" readonly="1"/>
                            <field name="rework_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Functional Checklist" col="3">
                        <field name="checklist_display_touch"/>
                        <field name="checklist_camera"/>
                        <field name="checklist_audio"/>
                        <field name="checklist_charging"/>
                        <field name="checklist_network"/>
                        <field name="checklist_wifi_bt"/>
                        <field name="checklist_software"/>
                        <field name="checklist_imei"/>
                        <field name="checklist_cosmetic"/>
                    </group>
                    <group string="Failure / Corrective Information">
                        <field name="failure_category"/>
                        <field name="failure_description"/>
                        <field name="corrective_note"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_mobile_device_qc" model="ir.actions.act_window">
        <field name="name">Device QC History</field>
        <field name="res_model">mobile.device.qc</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
