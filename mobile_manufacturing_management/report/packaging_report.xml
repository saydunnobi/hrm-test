<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_mobile_packaging_imei" model="report.paperformat">
        <field name="name">Mobile Packaging IMEI A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">12</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">8</field>
        <field name="margin_right">8</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_mobile_packaging_imei" model="ir.actions.report">
        <field name="name">Packaging Box IMEI List</field>
        <field name="model">mobile.packaging.batch</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">mobile_manufacturing_management.report_mobile_packaging_imei</field>
        <field name="report_file">mobile_manufacturing_management.report_mobile_packaging_imei</field>
        <field name="paperformat_id" ref="paperformat_mobile_packaging_imei"/>
        <field name="binding_model_id" ref="model_mobile_packaging_batch"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'IMEI_Box_%s' % (object.name)</field>
    </record>
</odoo>
