<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="messenger_crm_config_settings_view" model="ir.ui.view">
        <field name="name">res.config.settings.view.messenger.crm</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.action_general_configuration"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Social Inbox" name="messenger_crm_lead" groups="base.group_system">
                    <block title="Facebook Messenger &amp; Instagram DM" name="messenger_settings_block">
                        <setting string="Webhook Verify Token"
                                 help="A secret string you set here AND in Meta Developer Console to verify the webhook URL.">
                            <field name="messenger_verify_token" placeholder="e.g. my_secret_token_123"/>
                        </setting>
                        <setting string="Page Access Token"
                                 help="Your Facebook Page Access Token from Meta Developer Console. Used to fetch the sender's name.">
                            <field name="messenger_page_access_token" password="True"/>
                        </setting>
                        <setting string="Auto-create Lead"
                                 help="When ON, every new incoming message automatically becomes a CRM Lead. When OFF, you convert manually with 1 click.">
                            <field name="messenger_auto_lead"/>
                        </setting>
                        <setting string="Webhook URL" help="Copy this URL and paste it in Meta Developer Console → Webhooks.">
                            <div class="o_setting_box_content">
                                <code>/messenger/webhook</code>
                                <span class="text-muted ms-2">(prefix with your Odoo domain)</span>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
