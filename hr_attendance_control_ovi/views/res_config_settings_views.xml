<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_hr_attendance_control" model="ir.ui.view">
        <field name="name">res.config.settings.view.hr.attendance.control</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr_attendance.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='hr_attendance']" position="inside">

                <block title="Attendance Control" name="attendance_control_setting_container">
                    <setting string="Force Checkout" help="Automatically check-out an employee's open attendance when they start a new check-in.">
                        <field name="attendance_force_checkout"/>
                    </setting>
                    
                    <setting string="Auto Checkout Previous Days" help="During the nightly cron, also close any attendance that was left open from a previous day.">
                        <field name="attendance_checkout_previous_days"/>
                    </setting>

                    <setting string="Restrict Login / Check-in Time" help="Block Odoo login and attendance check-in during a specified time window. Admin is never blocked.">
                        <field name="attendance_restrict_login"/>
                        <div invisible="not attendance_restrict_login" class="content-group mt-3">
                            <div class="row w-100">
                                <label for="attendance_restrict_from" class="col-4 o_light_label" string="Restricted From" />
                                <field name="attendance_restrict_from" widget="float_time" class="col-8 col-lg-6 oe_inline" />
                            </div>
                            <div class="row w-100 mt-2">
                                <label for="attendance_restrict_to" class="col-4 o_light_label" string="Restricted Until" />
                                <field name="attendance_restrict_to" widget="float_time" class="col-8 col-lg-6 oe_inline" />
                            </div>
                            <div class="text-muted mt-2">
                                Use 24-hour format. The range can span midnight (e.g. 23:00 – 05:00).
                            </div>
                        </div>
                    </setting>
                </block>

            </xpath>
        </field>
    </record>

</odoo>
