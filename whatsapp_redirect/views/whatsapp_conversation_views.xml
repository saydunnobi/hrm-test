<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Conversation List View ─────────────────────────────────────────── -->
    <record id="whatsapp_conversation_view_list" model="ir.ui.view">
        <field name="name">whatsapp.conversation.view.list</field>
        <field name="model">whatsapp.conversation</field>
        <field name="arch" type="xml">
            <list>
                <field name="last_message_at" string="Last Message"/>
                <field name="contact_name" string="Name"/>
                <field name="phone_number" string="Phone"/>
                <field name="last_message_preview" string="Preview"/>
                <field name="state"/>
                <field name="lead_id"/>
                <button name="action_convert_to_lead"
                        string="→ Lead"
                        type="object"/>
            </list>
        </field>
    </record>

    <!-- ── Conversation Form View  (Chat Interface) ───────────────────────── -->
    <record id="whatsapp_conversation_view_form" model="ir.ui.view">
        <field name="name">whatsapp.conversation.view.form</field>
        <field name="model">whatsapp.conversation</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Chat">
                <header>
                    <button name="action_convert_to_lead"
                            string="Convert to Lead"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'converted'"/>
                    <button name="action_send_message_wizard"
                            string="✉ Reply"
                            type="object"
                            class="btn-success"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="open,converted,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="contact_name" placeholder="Contact Name"/>
                        </h1>
                        <h4 class="text-muted">
                            <field name="phone_number" readonly="1"/>
                        </h4>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <field name="last_message_at" readonly="1"/>
                        </group>
                        <group>
                            <field name="lead_id" readonly="1"/>
                            <field name="message_count" readonly="1" string="Total Messages"/>
                        </group>
                    </group>

                    <!-- Chat messages display -->
                    <notebook>
                        <page string="💬 Chat">
                            <field name="message_ids" nolabel="1"
                                   mode="list" readonly="1"
                                   widget="one2many">
                                <list>
                                    <field name="create_date" string="Time"/>
                                    <field name="direction" string="Dir"/>
                                    <field name="body" string="Message"/>
                                    <field name="status" optional="show"/>
                                    <field name="is_read" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Search View ───────────────────────────────────────────────────── -->
    <record id="whatsapp_conversation_view_search" model="ir.ui.view">
        <field name="name">whatsapp.conversation.view.search</field>
        <field name="model">whatsapp.conversation</field>
        <field name="arch" type="xml">
            <search>
                <field name="contact_name"/>
                <field name="phone_number"/>
                <filter string="Open" name="open" domain="[('state','=','open')]"/>
                <filter string="Converted" name="converted" domain="[('state','=','converted')]"/>
                <filter string="Has Unread" name="unread" domain="[('unread_count','>',0)]"/>
                <group string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                    <filter string="Date" name="group_date" context="{'group_by':'last_message_at'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Action ────────────────────────────────────────────────────────── -->
    <record id="whatsapp_conversation_action" model="ir.actions.act_window">
        <field name="name">WhatsApp Inbox</field>
        <field name="res_model">whatsapp.conversation</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="whatsapp_conversation_view_search"/>
        <field name="context">{'search_default_open': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No conversations yet!
            </p>
            <p>
                When someone sends a WhatsApp message to your business number,
                it will appear here. Click <strong>→ Lead</strong> to convert it to a CRM Lead.
            </p>
        </field>
    </record>

</odoo>
