<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_newspaper_customer_type_form" model="ir.ui.view">
        <field name="name">newspaper.customer.type.form</field>
        <field name="model">newspaper.customer.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_newspaper_customer_type_tree" model="ir.ui.view">
        <field name="name">newspaper.customer.type.list</field>
        <field name="model">newspaper.customer.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="action_newspaper_customer_type" model="ir.actions.act_window">
        <field name="name">Customer Types</field>
        <field name="res_model">newspaper.customer.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_action_newspaper_customer_types" parent="menu_newspaper_customer_types" action="action_newspaper_customer_type"/>
</odoo>
