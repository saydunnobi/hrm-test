<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_newspaper_ad_pricelist_form" model="ir.ui.view">
        <field name="name">newspaper.ad.pricelist.form</field>
        <field name="model">newspaper.ad.pricelist</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="customer_type_id"/>
                        <field name="position_id"/>
                        <field name="size_id"/>
                        <field name="base_price"/>
                        <field name="extra_price_per_day"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_newspaper_ad_pricelist_tree" model="ir.ui.view">
        <field name="name">newspaper.ad.pricelist.list</field>
        <field name="model">newspaper.ad.pricelist</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="customer_type_id"/>
                <field name="position_id"/>
                <field name="size_id"/>
                <field name="base_price"/>
            </list>
        </field>
    </record>

    <record id="action_newspaper_ad_pricelist" model="ir.actions.act_window">
        <field name="name">Ad Pricelists</field>
        <field name="res_model">newspaper.ad.pricelist</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_action_newspaper_pricelists" parent="menu_newspaper_pricelists" action="action_newspaper_ad_pricelist"/>
</odoo>
