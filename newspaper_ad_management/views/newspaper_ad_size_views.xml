<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_newspaper_ad_size_form" model="ir.ui.view">
        <field name="name">newspaper.ad.size.form</field>
        <field name="model">newspaper.ad.size</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="width"/>
                        <field name="height"/>
                        <field name="is_custom"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_newspaper_ad_size_tree" model="ir.ui.view">
        <field name="name">newspaper.ad.size.list</field>
        <field name="model">newspaper.ad.size</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="width"/>
                <field name="height"/>
                <field name="is_custom"/>
            </list>
        </field>
    </record>

    <record id="action_newspaper_ad_size" model="ir.actions.act_window">
        <field name="name">Ad Sizes</field>
        <field name="res_model">newspaper.ad.size</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_action_newspaper_sizes" parent="menu_newspaper_sizes" action="action_newspaper_ad_size"/>
</odoo>
