<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_newspaper_ad_order_form" model="ir.ui.view">
        <field name="name">newspaper.ad.order.form</field>
        <field name="model">newspaper.ad.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirm" type="object" invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_create_invoice" string="Create Invoice" type="object" invisible="state != 'confirmed'" class="oe_highlight"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,invoiced"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="customer_type_id"/>
                            <field name="payment_term_id"/>
                            <field name="income_account_id"/>
                        </group>
                        <group>
                            <field name="page_id"/>
                            <field name="position_id"/>
                            <field name="size_id"/>
                            <field name="is_custom_size" invisible="1"/>
                            <field name="custom_width" invisible="not is_custom_size"/>
                            <field name="custom_height" invisible="not is_custom_size"/>
                        </group>
                    </group>
                    <group>
                        <group string="Duration">
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="duration_days"/>
                        </group>
                        <group string="Pricing">
                            <field name="base_price"/>
                            <field name="total_price"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Invoicing Info" invisible="not invoice_id">
                            <field name="invoice_id" readonly="1"/>
                        </page>
                        <page string="Notes and Documents">
                            <group>
                                <field name="attachment_file" filename="attachment_name" widget="binary"/>
                                <field name="attachment_name" invisible="1"/>
                            </group>
                            <separator string="Additional Notes"/>
                            <field name="note" placeholder="Write any additional notes, conditions, or terms here..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_newspaper_ad_order_tree" model="ir.ui.view">
        <field name="name">newspaper.ad.order.list</field>
        <field name="model">newspaper.ad.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="page_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="total_price"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'confirmed'" decoration-warning="state == 'invoiced'"/>
            </list>
        </field>
    </record>

    <record id="action_newspaper_ad_order" model="ir.actions.act_window">
        <field name="name">Ad Orders</field>
        <field name="res_model">newspaper.ad.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_action_newspaper_orders" parent="menu_newspaper_orders" action="action_newspaper_ad_order"/>
</odoo>
