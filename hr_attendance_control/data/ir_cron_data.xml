<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Daily auto checkout cron – runs every day at 23:59 server time -->
        <record id="ir_cron_auto_checkout" model="ir.cron">
            <field name="name">HR Attendance: Daily Auto Check-Out at 23:59</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_checkout()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <!-- nextcall: tomorrow at 23:59 – Odoo will keep it rolling daily -->
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 23:59:00')"/>
            <field name="priority">5</field>
        </record>

    </data>
</odoo>
